# KAI Environment Variables
# Copy relevant lines to your shell profile (~/.zshrc or ~/.bashrc)
#
# Precedence: shell profile (process.env) > this .env file
# Keys exported in your shell profile always win over values here.

# ── Required ──────────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── AWS Bedrock (alternative to direct Anthropic) ────────────────
# Uncomment these if routing through AWS Bedrock instead of Anthropic
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-west-2
# AWS_PROFILE=default
# ANTHROPIC_MODEL=us.anthropic.claude-opus-4-0-20250514
# ANTHROPIC_SMALL_FAST_MODEL=us.anthropic.claude-sonnet-4-0-20250514

# ── Optional: GitHub ──────────────────────────────────────────────
# For GitHub hooks, PR review, repo skills
# GITHUB_TOKEN=ghp_your-token-here

# ── Optional: Research Agents ─────────────────────────────────────
# Google (Gemini researcher, Google Search)
# GEMINI_API_KEY=AIza...

# OpenAI (Codex researcher)
# OPENAI_API_KEY=sk-...

# xAI (Grok researcher)
# XAI_API_KEY=xai-...

# Perplexity (Perplexity researcher)
# PERPLEXITY_API_KEY=pplx-...

# DeepSeek (DeepSeek researcher)
# DEEPSEEK_API_KEY=sk-...

# Mistral (Mistral researcher)
# MISTRAL_API_KEY=...

# ── Optional: Web Scraping ────────────────────────────────────────
# Apify (social media scraping, data extraction)
# APIFY_API_KEY=apify_api_...

# Bright Data (proxy-based scraping)
# BRIGHTDATA_API_KEY=...

# ── Optional: Data APIs ───────────────────────────────────────────
# FRED (US economic indicators)
# FRED_API_KEY=...

# EIA (energy data)
# EIA_API_KEY=...

# ── Optional: Audio/Media ─────────────────────────────────────────
# ElevenLabs (text-to-speech, voice cloning)
# ELEVENLABS_API_KEY=...

# Replicate (image generation — Flux, etc.)
# REPLICATE_API_TOKEN=r8_...

# ── Optional: Notifications ───────────────────────────────────────
# Discord (bot notifications)
# DISCORD_BOT_TOKEN=...

# ntfy.sh (push notifications)
# NTFY_TOPIC=your-topic

# Twilio (SMS notifications)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+1...
# TWILIO_TO_NUMBER=+1...

# ── Optional: CI/CD ──────────────────────────────────────────────
# Jenkins (build triggers, status checks)
# JENKINS_USER=...
# JENKINS_TOKEN=...
# JENKINS_URL=https://...
