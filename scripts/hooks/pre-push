#!/usr/bin/env bash
# KAI / PAI pre-push hook — fast local feedback before CI.
#
# SINGLE SOURCE, divergence-proof: this one file is correct in BOTH repos by construction.
# It is synced pai-config → kai, so it must make NO hard assumption about which files exist
# in the repo it runs in. Every external dependency is existence-guarded ([ -f ... ]); the
# public-fork PII gate (section 0) is fully self-contained (no external script required).
#   - In pai-config: section 0 no-ops (remote isn't kai), verify-release runs (present).
#   - In kai (public): section 0 runs the inline gate, verify-release skips (absent by design).
#
# Installed by: bash scripts/install-hooks.sh   |   Bypass (auditable): git push --no-verify
set -euo pipefail

# ── R3. core.bare canary (incident 2026-06-22 — a stray tool flipped core.bare=true) ──
# MUST run FIRST: under core.bare=true, `git rev-parse --show-toplevel` (below) fails with
# "fatal: this operation must be run in a work tree" and aborts the hook before any later
# check — so the canary has to fire here, with its own explicit diagnostic, not later.
if [[ "$(git config --get core.bare 2>/dev/null || echo false)" == "true" ]]; then
  echo "❌ Pre-push BLOCKED: core.bare=true on a working repo (config corruption)."
  echo "   A stray tool likely flipped it (incident 2026-06-22). Fix: git config core.bare false"
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Sync-atomicity guard: refuse to push while a sync scrub is mid-flight (see scripts/hooks/pre-commit
# and sync-to-kai.sh). Only ever present in the kai repo; harmless no-op in pai-config.
GIT_DIR_PATH="$(git rev-parse --git-dir 2>/dev/null || echo .git)"
if [ -f "$GIT_DIR_PATH/.sync-scrub-in-progress" ]; then
  echo "🛡️  PUSH BLOCKED — sync scrub in progress ($GIT_DIR_PATH/.sync-scrub-in-progress)."
  echo "    Re-run sync-to-kai.sh to completion, then push. It may hold un-scrubbed content."
  exit 1
fi

# Pre-push receives, on stdin: <local-ref> <local-sha> <remote-ref> <remote-sha> (one line per ref).
# Capture it NOW (before any subshell consumes stdin) so the gate can scan the exact push range.
PUSH_STDIN="$(cat || true)"

# Branch workflow guard: changes should leave local repos through feature branches and PRs.
# Override only when the user explicitly approves a main-branch write in the current turn:
#   PAI_ALLOW_MAIN_WRITE=1 git push origin main
if [[ "${PAI_ALLOW_MAIN_WRITE:-}" != "1" ]]; then
  while read -r lref _lsha rref _rsha; do
    [[ -z "${lref:-}" ]] && continue
    if [[ "$lref" == "refs/heads/main" || "$rref" == "refs/heads/main" ]]; then
      echo ""
      echo "❌ Pre-push BLOCKED: direct main-branch push."
      echo "   Push a feature branch and open a PR instead."
      echo "   Explicit one-off override: PAI_ALLOW_MAIN_WRITE=1 git push ..."
      echo ""
      exit 1
    fi
  done <<< "$PUSH_STDIN"
fi

echo "── KAI pre-push checks ──"

# ── Compute the push range once (shared by the repo-safety + PII gates) ──────
# Pre-push stdin: <local-ref> <local-sha> <remote-ref> <remote-sha> per line.
# NOTE (known limitation, tracked): on a multi-ref push (rare — `git push` of several branches
# at once) this keeps only the LAST ref's range. Normal single-branch pushes are unaffected.
# A future hardening pass should accumulate all ref ranges; left out here to keep R1/R2 simple.
SAFE_RANGE=""
SAFE_TIP=""
SAFE_NEW_BRANCH=0
while read -r _lref lsha _rref rsha; do
  [[ -z "${lsha:-}" ]] && continue
  [[ "$lsha" =~ ^0+$ ]] && continue            # branch deletion — nothing to scan
  SAFE_TIP="$lsha"
  if [[ "${rsha:-}" =~ ^0+$ || -z "${rsha:-}" ]]; then
    # New branch: scan ONLY commits not already on the remote. Plain "$lsha" would be the
    # branch's ENTIRE ancestry (every historical author/deletion → false positives), and
    # "--not --all" wrongly excludes the very commits being pushed (they're on the local ref).
    # "--not --remotes=origin" = "what this push actually adds to origin".
    SAFE_RANGE="$lsha --not --remotes=origin"
    SAFE_NEW_BRANCH=1
  else
    SAFE_RANGE="$rsha..$lsha"                    # normal push — only new commits
  fi
done <<< "$PUSH_STDIN"

# ── R1. Repo-wipe / large-deletion guard (incident 2026-06-22 "seed") ────────
# A stray scaffolding tool once committed a "seed" that deleted the whole tree (1894 files).
# Block a push whose range deletes an implausible number of files. Override (audited):
#   PAI_ALLOW_LARGE_DELETE=1 git push ...
if [[ -n "$SAFE_RANGE" ]]; then
  DEL_THRESHOLD="${PAI_DELETE_THRESHOLD:-400}"
  # git log (not git diff) so both "$rsha..$lsha" and "$lsha --not --remotes=origin" forms work.
  # SAFE_RANGE is intentionally unquoted — it may carry multiple revision-walk args.
  # shellcheck disable=SC2086
  # `|| true` on grep: under pipefail, grep exits 1 when it filters everything out (0 deletions),
  # which would abort the hook (set -e). Guard each fail-prone stage.
  DELETED=$(git log --diff-filter=D --name-only --pretty=format: $SAFE_RANGE 2>/dev/null | { grep -v '^$' || true; } | sort -u | wc -l | tr -d ' ')
  if [[ "${DELETED:-0}" -gt "$DEL_THRESHOLD" ]]; then
    if [[ "${PAI_ALLOW_LARGE_DELETE:-}" == "1" ]]; then
      echo "⚠️  Large deletion ($DELETED files) ALLOWED via PAI_ALLOW_LARGE_DELETE=1 — logged."
      echo "$(date -u +%FT%TZ) push deletes=$DELETED range=$SAFE_RANGE override=1" \
        >> "$REPO_ROOT/.git/large-delete-overrides.log" 2>/dev/null || true
    else
      echo ""
      echo "❌ Pre-push BLOCKED: push range deletes $DELETED files (> $DEL_THRESHOLD threshold)."
      echo "   This is the signature of a repo-wipe / stray 'seed' commit (incident 2026-06-22)."
      echo "   If intentional: PAI_ALLOW_LARGE_DELETE=1 git push … (logged)."
      exit 1
    fi
  fi
fi

# ── R2. Author-identity guard (incident 2026-06-22 junk "T <t@t.t>") ─────────
# Reject pushing commits authored by a junk/placeholder identity. Allowlist is intentional:
# real maintainers only. Override (audited): PAI_ALLOW_AUTHOR=1.
if [[ -n "$SAFE_RANGE" ]]; then
  # SAFE_RANGE unquoted — may carry "$lsha --not --remotes=origin" for a new branch.
  # shellcheck disable=SC2086
  # grep -vi exits 1 when ALL authors are allowlisted (empty) — guard it so pipefail/set -e
  # doesn't abort the hook on the common (good) case.
  BAD_AUTHORS=$(git log --format='%ae' $SAFE_RANGE 2>/dev/null \
    | { grep -viE '@(kai-cli\.com|users\.noreply\.github\.com|anthropic\.com|openai\.com)$' || true; } \
    | sort -u || true)
  if [[ -n "$BAD_AUTHORS" ]]; then
    if [[ "${PAI_ALLOW_AUTHOR:-}" == "1" ]]; then
      echo "⚠️  Non-allowlisted author(s) ALLOWED via PAI_ALLOW_AUTHOR=1: $BAD_AUTHORS"
    else
      echo ""
      echo "❌ Pre-push BLOCKED: commit(s) in range authored by non-allowlisted identity:"
      echo "$BAD_AUTHORS" | sed 's/^/     /'
      echo "   Junk identities (e.g. t@t.t) signal a stray tool. Fix author or:"
      echo "   PAI_ALLOW_AUTHOR=1 git push … (if a new real author is expected)."
      exit 1
    fi
  fi
fi

# ── 0. PII / personal-data gate (public fork only) ───────────────────────────
# Last line of defense against personal data reaching the public fork — INDEPENDENT of the sync
# mechanism (catches anything the sync excludes missed). Scans ONLY the commits being pushed.
# This hook is itself public, so it embeds NO PII regexes: personal-data PATHS are safe to list
# here (dir names), and PII CONTENT patterns load from an external file when available
# (pii-patterns.json is excluded from the public fork by design) with a built-in shape fallback.
GATE_REMOTE_URL=$(git remote get-url origin 2>/dev/null || echo "")
if [[ "$GATE_REMOTE_URL" == *"kai-cli/kai"* ]]; then
  echo "Scanning push range for personal data (public-fork gate)..."

  # Determine the range of commits being pushed (from stdin; fall back to HEAD).
  GATE_RANGE=""
  while read -r _lref lsha _rref rsha; do
    [[ -z "${lsha:-}" ]] && continue
    [[ "$lsha" =~ ^0+$ ]] && continue        # branch deletion — nothing to scan
    if [[ "${rsha:-}" =~ ^0+$ || -z "${rsha:-}" ]]; then
      GATE_RANGE="$lsha"                      # new branch — scan the tip commit
    else
      GATE_RANGE="$rsha..$lsha"               # normal push — scan only new commits
    fi
  done <<< "$PUSH_STDIN"
  [[ -z "$GATE_RANGE" ]] && GATE_RANGE="HEAD"

  # 0a. Personal-data PATHS that must never appear in the public fork (safe to list — just names).
  # Only consider ADDED/MODIFIED/COPIED/RENAMED files (--diff-filter=ACMR) — DELETIONS can't leak
  # (a removed file is leaving the repo), and blocking on them would prevent cleanup of junk.
  GATE_PATHS='^(projects/|daemon/|memcarry/store/|MEMORY/(memcarry|LEARNING|STATE|RELATIONSHIP|WORK|STAGING|CAPABILITIES)/|PAI/USER/|\.claude/|tests/\.tmp)'
  GATE_CHANGED=$(git diff --name-only --diff-filter=ACMR "$GATE_RANGE" 2>/dev/null || git show --name-only --diff-filter=ACMR --format= "$GATE_RANGE" 2>/dev/null || true)
  GATE_LEAKED=$(echo "$GATE_CHANGED" | grep -E "$GATE_PATHS" || true)
  if [[ -n "$GATE_LEAKED" ]]; then
    echo ""
    echo "❌ Pre-push BLOCKED: personal-data paths in the push range:"
    echo "$GATE_LEAKED" | sed 's/^/     /'
    echo "   These must never reach the public fork. Remove them from the commit(s)."
    echo "   Escape hatch: git push --no-verify (auditable, discouraged)"
    exit 1
  fi

  # 0b. PII CONTENT scan. Load regexes from an external file if present (never committed to kai);
  #     otherwise fall back to a minimal built-in check so the gate still functions.
  GATE_PII_FILE="${KAI_PII_PATTERNS:-$REPO_ROOT/scripts/pii-patterns.json}"
  GATE_PII_REGEX=""
  if [[ -f "$GATE_PII_FILE" ]] && command -v jq >/dev/null 2>&1; then
    GATE_PII_REGEX=$(jq -r '.[]' "$GATE_PII_FILE" 2>/dev/null | paste -sd '|' -)
  fi
  # Minimal built-in fallback (generic shapes, not specific identifiers): home-dir paths + token shapes.
  GATE_BUILTIN='/Users/[a-z]+\.[a-z]+/|github_pat_[A-Za-z0-9_]+|ghp_[A-Za-z0-9]{36}|gho_[A-Za-z0-9]+|sk-ant-[A-Za-z0-9]+'
  GATE_SCAN="$GATE_BUILTIN"
  [[ -n "$GATE_PII_REGEX" ]] && GATE_SCAN="$GATE_PII_REGEX|$GATE_BUILTIN"

  # Known-safe GENERIC placeholders used in docs/tests/examples — these are the scrub TARGETS and
  # deliberate examples, never real PII. Filtered out so the home-dir shape pattern doesn't flag them.
  # (Real usernames never look like these.) Keep tightly scoped to avoid masking genuine leaks.
  GATE_ALLOW='/Users/(your\.name|you|a\.b|x\.y|user|username|example|name|test)/'

  # Scan ADDED content in the range (--diff-filter=ACMR: skip deletions; exclude this hook itself,
  # which documents patterns). `grep '^+'` already targets added lines, but filtering the file set
  # too avoids scanning the '+' noise from rename/copy diffs.
  GATE_ADDED=$(git diff --diff-filter=ACMR "$GATE_RANGE" -- . ':(exclude)scripts/hooks/pre-push' 2>/dev/null | grep '^+' || true)
  GATE_HITS=$(echo "$GATE_ADDED" | grep -niE "$GATE_SCAN" | grep -vE "$GATE_ALLOW" | head -20 || true)
  if [[ -n "$GATE_HITS" ]]; then
    echo ""
    echo "❌ Pre-push BLOCKED: possible PII / secrets in the pushed content:"
    # Redacted preview only — never echo a full matched secret.
    echo "$GATE_HITS" | sed -E 's/(github_pat_|gh[po]_|sk-ant-)[A-Za-z0-9_-]+/\1***REDACTED***/g' | sed 's/^/     /'
    echo "   Scrub these before pushing to the public fork."
    echo "   Escape hatch: git push --no-verify (auditable, discouraged)"
    exit 1
  fi
  echo "✅ No personal data in push range"
fi

# ── 1. Test suite ────────────────────────────────────────────
# Parse Bun's test summary instead of grepping one substring. Integration tests that spawn
# subprocesses can produce a single flaky fail under parallel load — retry once before blocking.
LOCAL_CHANGED_FILES=""
if [[ -n "$SAFE_RANGE" ]]; then
  # SAFE_RANGE unquoted — may carry "$lsha --not --remotes=origin" for a new branch.
  # shellcheck disable=SC2086
  LOCAL_CHANGED_FILES=$(git log --diff-filter=ACMR --name-only --pretty=format: $SAFE_RANGE 2>/dev/null \
    | { grep -v '^$' || true; } \
    | sort -u || true)
fi

LOCAL_RUN_FULL_TESTS=1
if [[ "${PAI_PRE_PUSH_FULL_TESTS:-}" == "1" ]]; then
  LOCAL_RUN_FULL_TESTS=1
elif [[ -n "$LOCAL_CHANGED_FILES" ]]; then
  LOCAL_RUN_FULL_TESTS=0
  while IFS= read -r changed_path; do
    [[ -z "$changed_path" ]] && continue
    case "$changed_path" in
      *.md|docs/*|README.md|CHANGELOG.md|MEMORY/KNOWLEDGE/*.md|MEMORY/WISDOM/*|MEMORY/memcarry/store/atoms/*|auto-memory/MEMORY.md|auto-memory/codex-secondary-validator.md)
        ;;
      *)
        LOCAL_RUN_FULL_TESTS=1
        break
        ;;
    esac
  done <<< "$LOCAL_CHANGED_FILES"
fi

if [[ "$LOCAL_RUN_FULL_TESTS" == "1" ]]; then
  echo "Running tests (CI simulation: PAI_DIR=\$REPO_ROOT)..."
  TEST_OUTPUT=$(PAI_DIR="$REPO_ROOT" bun test --cwd "$REPO_ROOT" 2>&1)
  TEST_STATUS=$?
  echo "$TEST_OUTPUT"
  if ! printf '%s\n' "$TEST_OUTPUT" | bun "$REPO_ROOT/scripts/bun-test-gate.ts" --exit-code "$TEST_STATUS" --label "pre-push bun test"; then
    echo ""
    echo "⚠️  Test run had failures — retrying once (subprocess spawn flakiness)..."
    TEST_OUTPUT=$(PAI_DIR="$REPO_ROOT" bun test --cwd "$REPO_ROOT" 2>&1)
    TEST_STATUS=$?
    echo "$TEST_OUTPUT"
    if ! printf '%s\n' "$TEST_OUTPUT" | bun "$REPO_ROOT/scripts/bun-test-gate.ts" --exit-code "$TEST_STATUS" --label "pre-push bun test retry"; then
      echo ""
      echo "❌ Pre-push blocked: test suite has failures (failed on retry too)."
      echo "   Fix failing tests, then push again."
      echo "   Escape hatch: git push --no-verify (auditable, not encouraged)"
      exit 1
    fi
    echo "✅ Retry passed."
  fi
else
  echo "Skipping full test suite for docs/memory-only push range."
  echo "Set PAI_PRE_PUSH_FULL_TESTS=1 to force local full-suite validation."
fi

# ── 2. Manifest count alignment ──────────────────────────────
if [[ -f "$REPO_ROOT/manifest.json" ]]; then
  echo ""
  echo "Checking manifest counts..."
  M_SKILLS=$(grep -oE '"skills":\s*[0-9]+' "$REPO_ROOT/manifest.json" | grep -oE '[0-9]+')
  M_HOOKS=$(grep -oE '"hooks":\s*[0-9]+' "$REPO_ROOT/manifest.json" | grep -oE '[0-9]+')
  F_SKILLS=$(find "$REPO_ROOT/skills" -name SKILL.md -not -path '*/.archive/*' | wc -l | tr -d ' ')
  F_HOOKS=$(find "$REPO_ROOT/hooks" -maxdepth 1 -name '*.hook.ts' | wc -l | tr -d ' ')
  if [[ "$M_SKILLS" != "$F_SKILLS" ]] || [[ "$M_HOOKS" != "$F_HOOKS" ]]; then
    echo ""
    echo "❌ Pre-push blocked: manifest counts stale."
    echo "   Manifest: $M_SKILLS skills, $M_HOOKS hooks"
    echo "   Filesystem: $F_SKILLS skills, $F_HOOKS hooks"
    echo "   Run: bun PAI/Tools/BuildManifest.ts && bun PAI/Tools/BuildDocs.ts"
    exit 1
  fi
  echo "✅ Manifest counts match filesystem"
fi

# ── 3. BuildDocs freshness ───────────────────────────────────
if [[ -f "$REPO_ROOT/PAI/Tools/BuildDocs.ts" ]]; then
  echo ""
  echo "Checking marker freshness..."
  if ! bun "$REPO_ROOT/PAI/Tools/BuildDocs.ts" --check 2>&1; then
    echo ""
    echo "❌ Pre-push blocked: stale marker regions."
    echo "   Run: bun PAI/Tools/BuildDocs.ts"
    echo "   Escape hatch: git push --no-verify (auditable, not encouraged)"
    exit 1
  fi
fi

# ── 4. Quick release verification (public-fork readiness check) ──────────────
# verify-release.sh validates that the PUBLIC fork has no leaks. It is meaningless against
# pai-config itself (which contains PII by design — MEMORY/, Plans/, USER/ never sync to kai),
# so it must run ONLY in the kai context. It's also EXCLUDED from the public fork (its PII
# patterns ARE PII). Both conditions guarded → correct in every repo by construction:
#   - pai-config (remote≠kai)         → skip (never scan the private source)
#   - kai (remote=kai, script absent) → skip gracefully (section 0's inline gate is the real net)
#   - kai-with-script (both true)     → run
REMOTE_URL=$(git remote get-url origin 2>/dev/null || echo "")
if [[ "$REMOTE_URL" == *"kai-cli/kai"* && -f "$REPO_ROOT/scripts/verify-release.sh" ]]; then
  echo ""
  echo "Running quick verification..."
  if ! bash "$REPO_ROOT/scripts/verify-release.sh" --quick 2>&1; then
    echo ""
    echo "❌ Pre-push blocked: verify-release.sh --quick failed."
    echo "   Fix the issues above, then push again."
    echo "   Escape hatch: git push --no-verify (auditable, not encouraged)"
    exit 1
  fi
else
  echo ""
  echo "Skipping verify-release.sh (PAI dev repo, or absent on the public fork — section 0 gate covers leaks)"
fi

echo ""
echo "✅ Pre-push checks passed."
exit 0
