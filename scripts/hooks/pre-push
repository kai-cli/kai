#!/usr/bin/env bash
# KAI pre-push hook — fast local feedback before CI.
# Runs bun test + verify-release.sh --quick.
# Installed by: bash scripts/install-hooks.sh
# Bypass (auditable): git push --no-verify
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Pre-push receives, on stdin: <local-ref> <local-sha> <remote-ref> <remote-sha> (one line per ref).
# Capture it now (before any subshell consumes stdin) so check 0 can scan the exact push range.
PUSH_STDIN="$(cat || true)"

echo "── KAI pre-push checks ──"

# ── 0. PII / personal-data gate (kai public fork only) ───────────────────────
# Last line of defense against personal data reaching the public fork — independent of the
# sync mechanism (catches anything sync excludes missed). Scans ONLY the commits being pushed.
# This hook is itself public, so it embeds NO PII regexes: personal-data PATHS are safe to list
# here (dir names), and PII content patterns are loaded from an external file when available
# (pii-patterns.json is excluded from the public fork by design).
GATE_REMOTE_URL=$(git remote get-url origin 2>/dev/null || echo "")
if [[ "$GATE_REMOTE_URL" == *"kai-cli/kai"* ]]; then
  echo "Scanning push range for personal data (public-fork gate)..."

  # Determine the range of commits being pushed (from stdin; fall back to HEAD).
  GATE_RANGE=""
  while read -r _lref lsha _rref rsha; do
    [[ -z "${lsha:-}" ]] && continue
    [[ "$lsha" =~ ^0+$ ]] && continue        # branch deletion — nothing to scan
    if [[ "${rsha:-}" =~ ^0+$ || -z "${rsha:-}" ]]; then
      GATE_RANGE="$lsha"                      # new branch — scan the tip commit
    else
      GATE_RANGE="$rsha..$lsha"               # normal push — scan only new commits
    fi
  done <<< "$PUSH_STDIN"
  [[ -z "$GATE_RANGE" ]] && GATE_RANGE="HEAD"

  # 0a. Personal-data PATHS that must never appear in the public fork (safe to list — just names).
  GATE_PATHS='^(projects/|daemon/|memcarry/store/|MEMORY/(memcarry|LEARNING|STATE|RELATIONSHIP|WORK|STAGING|CAPABILITIES)/|PAI/USER/|\.claude/)'
  GATE_CHANGED=$(git diff --name-only "$GATE_RANGE" 2>/dev/null || git show --name-only --format= "$GATE_RANGE" 2>/dev/null || true)
  GATE_LEAKED=$(echo "$GATE_CHANGED" | grep -E "$GATE_PATHS" || true)
  if [[ -n "$GATE_LEAKED" ]]; then
    echo ""
    echo "❌ Pre-push BLOCKED: personal-data paths in the push range:"
    echo "$GATE_LEAKED" | sed 's/^/     /'
    echo "   These must never reach the public fork. Remove them from the commit(s)."
    echo "   Escape hatch: git push --no-verify (auditable, discouraged)"
    exit 1
  fi

  # 0b. PII CONTENT scan. Load regexes from an external file if present (never committed to kai);
  #     otherwise fall back to a minimal built-in check so the gate still functions.
  GATE_PII_FILE="${KAI_PII_PATTERNS:-$HOME/Projects/pai-config/scripts/pii-patterns.json}"
  GATE_PII_REGEX=""
  if [[ -f "$GATE_PII_FILE" ]] && command -v jq >/dev/null 2>&1; then
    GATE_PII_REGEX=$(jq -r '.[]' "$GATE_PII_FILE" 2>/dev/null | paste -sd '|' -)
  fi
  # Minimal built-in fallback (generic shapes, not specific identifiers): home-dir paths + token shapes.
  GATE_BUILTIN='/Users/[a-z]+\.[a-z]+/|github_pat_[A-Za-z0-9_]+|ghp_[A-Za-z0-9]{36}|gho_[A-Za-z0-9]+|sk-ant-[A-Za-z0-9]+'
  GATE_SCAN="$GATE_BUILTIN"
  [[ -n "$GATE_PII_REGEX" ]] && GATE_SCAN="$GATE_PII_REGEX|$GATE_BUILTIN"

  # Scan added content in the range (exclude this hook itself — it documents patterns).
  GATE_ADDED=$(git diff "$GATE_RANGE" -- . ':(exclude)scripts/hooks/pre-push' 2>/dev/null | grep '^+' || true)
  GATE_HITS=$(echo "$GATE_ADDED" | grep -niE "$GATE_SCAN" | head -20 || true)
  if [[ -n "$GATE_HITS" ]]; then
    echo ""
    echo "❌ Pre-push BLOCKED: possible PII / secrets in the pushed content:"
    # Redacted preview only — never echo a full matched secret.
    echo "$GATE_HITS" | sed -E 's/(github_pat_|gh[po]_|sk-ant-)[A-Za-z0-9_-]+/\1***REDACTED***/g' | sed 's/^/     /'
    echo "   Scrub these before pushing to the public fork."
    echo "   Escape hatch: git push --no-verify (auditable, discouraged)"
    exit 1
  fi
  echo "✅ No personal data in push range"
fi

# ── 1. Test suite ────────────────────────────────────────────
# Note: bun 1.3.x has a known crash-on-exit bug (SIGABRT after tests complete).
# We capture output and check for "0 fail" in the summary line rather than
# trusting the exit code alone.
# Integration tests that spawn subprocesses (e.g. GitHubWriteGuard) can produce
# a single flaky fail under parallel load — retry once before blocking.
echo "Running tests (CI simulation: PAI_DIR=\$REPO_ROOT)..."
TEST_OUTPUT=$(PAI_DIR="$REPO_ROOT" bun test --cwd "$REPO_ROOT" 2>&1) || true
echo "$TEST_OUTPUT"
if echo "$TEST_OUTPUT" | grep -q "[1-9][0-9]* fail"; then
  echo ""
  echo "⚠️  Test run had failures — retrying once (subprocess spawn flakiness)..."
  TEST_OUTPUT=$(PAI_DIR="$REPO_ROOT" bun test --cwd "$REPO_ROOT" 2>&1) || true
  echo "$TEST_OUTPUT"
  if echo "$TEST_OUTPUT" | grep -q "[1-9][0-9]* fail"; then
    echo ""
    echo "❌ Pre-push blocked: test suite has failures (failed on retry too)."
    echo "   Fix failing tests, then push again."
    echo "   Escape hatch: git push --no-verify (auditable, not encouraged)"
    exit 1
  fi
  echo "✅ Retry passed."
fi

# ── 2. Manifest count alignment ──────────────────────────────
if [[ -f "$REPO_ROOT/manifest.json" ]]; then
  echo ""
  echo "Checking manifest counts..."
  M_SKILLS=$(grep -oE '"skills":\s*[0-9]+' "$REPO_ROOT/manifest.json" | grep -oE '[0-9]+')
  M_HOOKS=$(grep -oE '"hooks":\s*[0-9]+' "$REPO_ROOT/manifest.json" | grep -oE '[0-9]+')
  F_SKILLS=$(find "$REPO_ROOT/skills" -name SKILL.md | wc -l | tr -d ' ')
  F_HOOKS=$(find "$REPO_ROOT/hooks" -maxdepth 1 -name '*.hook.ts' | wc -l | tr -d ' ')
  if [[ "$M_SKILLS" != "$F_SKILLS" ]] || [[ "$M_HOOKS" != "$F_HOOKS" ]]; then
    echo ""
    echo "❌ Pre-push blocked: manifest counts stale."
    echo "   Manifest: $M_SKILLS skills, $M_HOOKS hooks"
    echo "   Filesystem: $F_SKILLS skills, $F_HOOKS hooks"
    echo "   Run: bun PAI/Tools/BuildManifest.ts && bun PAI/Tools/BuildDocs.ts"
    exit 1
  fi
  echo "✅ Manifest counts match filesystem"
fi

# ── 3. BuildDocs freshness ───────────────────────────────────
if [[ -f "$REPO_ROOT/PAI/Tools/BuildDocs.ts" ]]; then
  echo ""
  echo "Checking marker freshness..."
  if ! bun "$REPO_ROOT/PAI/Tools/BuildDocs.ts" --check 2>&1; then
    echo ""
    echo "❌ Pre-push blocked: stale marker regions."
    echo "   Run: bun PAI/Tools/BuildDocs.ts"
    echo "   Escape hatch: git push --no-verify (auditable, not encouraged)"
    exit 1
  fi
fi

# ── 4. Quick release verification (kai only — pai-config has PII by design) ──
REMOTE_URL=$(git remote get-url origin 2>/dev/null || echo "")
if [[ "$REMOTE_URL" == *"kai-cli/kai"* ]]; then
  echo ""
  echo "Running quick verification..."
  if ! bash "$REPO_ROOT/scripts/verify-release.sh" --quick 2>&1; then
    echo ""
    echo "❌ Pre-push blocked: verify-release.sh --quick failed."
    echo "   Fix the issues above, then push again."
    echo "   Escape hatch: git push --no-verify (auditable, not encouraged)"
    exit 1
  fi
else
  echo ""
  echo "Skipping verify-release.sh (not kai repo)"
fi

echo ""
echo "✅ Pre-push checks passed."
exit 0
