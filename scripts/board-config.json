{
  "port": 3333,
  "terminal": "iterm",
  "workRoot": "~/.claude/MEMORY/WORK",
  "scanDirs": [
    "~/.claude/MEMORY/WORK",
    "~/.claude/docs/v45-staging/work",
    "~/.claude/docs/v46-staging/work"
  ],
  "projectsDir": "~/Projects",
  "autoDiscover": true,
  "ignored": [
    "node_modules",
    ".git",
    "__pycache__",
    ".venv",
    "Personal"
  ],
  "library": [
    {
      "name": "Release Notes Generator",
      "path": "~/Projects/release-notes/",
      "description": "ISP release note drafting pipeline \u2014 config-driven, multi-audience output",
      "tags": [
        "yourcompany",
        "releases",
        "writing"
      ],
      "pinned": true
    },
    {
      "name": "Release Calendar & Gap Analysis",
      "path": "~/Projects/Knowledge/releases/",
      "description": "7-board release tracking with gap analysis, ISP bug exposure, weekly calendar",
      "tags": [
        "yourcompany",
        "releases",
        "tracking"
      ],
      "pinned": false
    },
    {
      "name": "TR-069/TR-369 Research",
      "path": "~/Projects/TR-069_TR-369/",
      "description": "Open standards compliance research, data model analysis, USP protocol work",
      "tags": [
        "standards",
        "yourcompany",
        "research"
      ],
      "pinned": true
    },
    {
      "name": "Knowledge Base",
      "path": "~/Projects/Knowledge/",
      "description": "Indexed knowledge store \u2014 firmware, standards, security, AI reference material",
      "tags": [
        "knowledge",
        "reference"
      ],
      "pinned": true
    },
    {
      "name": "Serial Router Monitor",
      "path": "~/Projects/_archive/serial-router-monitor/",
      "description": "USB serial console tool for router log capture and device assessment (archived)",
      "tags": [
        "yourcompany",
        "tools",
        "hardware"
      ],
      "pinned": false
    },
    {
      "name": "KAI / PAI System (v5.8.0)",
      "path": "~/.claude/",
      "description": "Personal AI Infrastructure \u2014 Algorithm v3.13.0, skills, hooks, agents, terminal adapters, work loaders, session lifecycle",
      "tags": [
        "ai",
        "infrastructure"
      ],
      "pinned": true
    },
    {
      "name": "Firmware Inspector",
      "path": "~/Projects/Firmware_Inspector/firmware-inspector/",
      "description": "OpenWRT device inspection toolkit \u2014 serial/SSH access, TR-181 validation, YAML rules, safety policy, evidence collection",
      "tags": [
        "yourcompany",
        "tools",
        "firmware",
        "tr-181"
      ],
      "pinned": true
    },
    {
      "name": "CLI Hidden Commands Reference",
      "path": "~/Projects/cli-hidden-commands/",
      "description": "Undocumented CLI commands reference guide",
      "tags": [
        "reference",
        "tools"
      ],
      "pinned": true
    }
  ],
