{
  "port": 3333,
  "scanDirs": [
    "~/.claude/MEMORY/WORK"
  ],
  "projectsDir": "~/Projects",
  "autoDiscover": true,
  "ignored": [
    "node_modules",
    ".git",
    "__pycache__",
    ".venv",
    "Personal"
  ],
  "library": [
    {
      "name": "KAI System",
      "path": "~/.claude/",
      "description": "Personal AI Infrastructure — Algorithm, skills, hooks, agents",
      "tags": [
        "ai",
        "infrastructure"
      ],
      "pinned": true
    },
    {
      "name": "Example Project",
      "path": "~/Projects/my-project/",
      "description": "Add your own projects here — board auto-discovers from projectsDir",
      "tags": [
        "example"
      ],
      "pinned": false
    }
  ],
  "archived": [],
  "ralphLoop": {
    "defaultBudget": 5,
    "defaultMaxIterations": 5,
    "defaultModel": "opus"
  },
  "docker": {
    "enabled": true,
    "image": "oven/bun:latest",
    "memoryLimit": "2g",
    "cpuLimit": "2.0",
    "timeout": 1800
  }
}
