{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PAI to KAI sync manifest",
  "type": "object",
  "required": ["version", "private", "kai_only", "public"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "private": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "kai_only": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "stale_kai_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "default": []
    },
    "public": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "notes": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
