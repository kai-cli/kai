    "MEMORY/RELATIONSHIP/.gitkeep",
    "MEMORY/SECURITY/.gitkeep",
    "MEMORY/STAGING/.gitkeep",
    "MEMORY/STATE/.gitkeep",
    "MEMORY/WORK/.gitkeep",
    "MEMORY/LEARNING/",
    "MEMORY/RELATIONSHIP/",
    "MEMORY/SECURITY/",
    "MEMORY/STATE/",
    "MEMORY/WORK/",
