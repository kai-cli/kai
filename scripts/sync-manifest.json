    "tests/LiteralReplace.test.ts",
    "tests/PromptLatencyReport.test.ts",
    "tests/fixtures/ada-registry.md",
    "ada/",
    "TOOLS.md",
    "TOOLS-FULL.md",
    "CAPABILITIES.md",
    "MEMORY/CAPABILITIES/",
    "projects/",
    "USER/",
    ".claude/",
    "History/",
    "specs/",
    "docs/v46-staging/",
    "docs/VERSIONING.md"
