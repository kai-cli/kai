// PAI Hook Configuration
// Registers hook handlers for all Claude Code lifecycle events.
// All paths use ${PAI_DIR} which resolves to ~/.claude at runtime.
//
// IMPORTANT: All hooks MUST go through run-hook.sh to redirect stderr.
// Direct hook calls cause "hook error" messages in Claude Code UI.
// Pattern: "${PAI_DIR}/hooks/lib/run-hook.sh HookName.hook.ts"
//
// Async policy: Hooks that only write files/state get "async": true.
// Sync hooks output JSON to stdout (additionalContext, decision, continue).
//
// Run `bun ~/.claude/hooks/handlers/BuildSettings.ts` after editing to
// regenerate settings.json.

{
  // Status line command — shown in terminal title/status bar
  "statusLine": {
    "type": "command",
    "command": "bun $PAI_DIR/statusline.ts"
  },

  // Hook registrations by lifecycle event
  "hooks": {
    // PreToolUse — runs before each tool invocation (all sync — they output decisions)
    "PreToolUse": [
      {
        // Security validation for filesystem-mutating tools
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SecurityValidator.hook.ts" },
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh GitHubWriteGuard.hook.ts" }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SecurityValidator.hook.ts" }]
      },
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SecurityValidator.hook.ts" }]
      },
      {
        "matcher": "Read",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SecurityValidator.hook.ts" }]
      },
      {
        // Terminal state tracking + teal tab for interactive prompts
        "matcher": "AskUserQuestion",
        "hooks": [
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SetQuestionTab.hook.ts" }
        ]
      },
      {
        // Agent spawn guard — validates agent parameters before execution
        "matcher": "Task",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh AgentExecutionGuard.hook.ts" }]
      },
      {
        // Skill invocation guard — validates skill calls
        "matcher": "Skill",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SkillGuard.hook.ts" }]
      },
      {
        // URL validation — blocks internal network ranges, flags suspicious domains
        "matcher": "WebFetch",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh WebFetchGuard.hook.ts" }]
      },
      {
        "matcher": "WebSearch",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh WebFetchGuard.hook.ts" }]
      }
    ],

    // PostToolUse — runs after each tool invocation
    "PostToolUse": [
      {
        // Restore terminal state after interactive prompt resolves
        "matcher": "AskUserQuestion",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh QuestionAnswered.hook.ts" }]
      },
      {
        // Sync PRD frontmatter to work.json when PRD files are written
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh PRDSync.hook.ts" }]
      },
      {
        "matcher": "Edit",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh PRDSync.hook.ts" }]
      },
      {
        // Scan tool output for leaked secrets (API keys, tokens, private keys)
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SecretOutputDetector.hook.ts" }]
      },
      {
        "matcher": "WebFetch",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SecretOutputDetector.hook.ts" }]
      },
      {
        // W5a: ReadActivity merges ReadTracker (routing-candidate log) + MemoryAccessTracker (eviction
        // scoring) into one PostToolUse:Read parse. Path-disjoint branches; async, no stdout.
        "matcher": "Read",
        "hooks": [{ "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh ReadActivity.hook.ts", "async": true }]
      }
    ],

    // SessionEnd — W4: consolidated into ONE composite orchestrator (was 10 individual
    // entries). SessionEndComposite spawns each sub-hook via run-hook.sh (timeouts preserved),
    // applies a trivial-session gate (skips inference on tiny sessions; flag
    // config/settings.json → sessionEnd.useComposite=false disables the gate = run all).
    // Always-run: SessionCleanup, UpdateCounts, MemoryTimeline, MemCapture, IntegrityCheck.
    // Inference-gated: InsightExtractor, KnowledgeSync, WorkCompletionLearning, SessionSummary,
    // RelationshipMemory. Rollback: git revert this commit. The 10 individual .hook.ts files are
    // retained (re-wireable). See MEMORY/WORK/20260605-140510_w4-sessionend-composite/PRD.md.
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SessionEndComposite.hook.ts", "async": true }
        ]
      }
    ],

    // UserPromptSubmit — mix of sync (output-producing) and async (analytics/inference)
    "UserPromptSubmit": [
      {
        "hooks": [
          // --- SYNC hooks (output additionalContext or continue flags) ---
          // Secret scanning — outputs continue flag to block credential leaks
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SecretScanner.hook.ts" },
          // Surface relevant project memories next to the user's prompt
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh MemoryRecall.hook.ts" },
          // Memcarry: surface verify-at-load drift from this session's resume (read-once, annotate-only)
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh MemDrift.hook.ts" },
          // Local context injection — outputs additionalContext
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh LocalContextFirst.hook.ts" },
          // Classify effort tier and inject context modifications
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh ModeClassifier.hook.ts" },
          // Detect PAI output format violations and inject correction hint
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh FormatReminder.hook.ts" },
          // Remind when a plan is awaiting approval
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh PlanApprovalGuard.hook.ts" },
          // Auto-generate four-word session names (fast, no inference)
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh SessionAutoName.hook.ts" },

          // --- ASYNC hooks (inference calls, analytics — no stdout needed) ---
          // v5.6: Detect correction patterns and capture behavioral instincts
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh InstinctCapture.hook.ts", "async": true },
          // W5b: PromptAnalysis removed — it wrote a {tabTitle,sessionName} cache with ZERO readers
          // (a never-wired consolidator). SessionAutoName owns sessionName, UpdateTabTitle owns tabTitle.
          // Capture 1-10 ratings from prompt patterns + implicit sentiment
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh RatingCapture.hook.ts", "async": true },
          // W10: TerminalState's UPS branch removed (duplicated UpdateTabTitle). UpdateTabTitle owns the title.
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh UpdateTabTitle.hook.ts", "async": true }
        ]
      }
    ],

    // SessionStart — sync (context injection happens here)
    "SessionStart": [
      {
        "hooks": [
          // Verify environment integrity (symlink, config health)
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh HealthCheck.hook.ts" },
          // Environment status — warns if critical keys missing
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh EnvironmentStatus.hook.ts" },
          // Initialize terminal state tracking
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh TerminalState.hook.ts" },
          // Inject relationship, learning, and work context
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh LoadContext.hook.ts" },
          // Memcarry: inject cached resume-state (warm cold-start) + kick detached verify-at-load
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh MemResume.hook.ts" },
          // Check PAI version against repo
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh CheckVersion.hook.ts" },
          // Display PAI startup banner
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh StartupGreeting.hook.ts" },
          // One-time first-session orientation (fires once after install)
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh FirstSessionOnboarding.hook.ts" },
          // Rebuild CLAUDE.md if algorithm version or DA name changed
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh handlers/BuildCLAUDE.ts" },
          // Rebuild settings.json from config/*.jsonc if any config file is newer
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh handlers/BuildSettings.ts" },
          // Validate settings.json against schema (warns on invalid config)
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh ConfigValidation.hook.ts" }
        ]
      },
      {
        // Post-compaction recovery — re-inject context after context window compaction
        "matcher": "compact",
        "hooks": [
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh PostCompactRecovery.hook.ts" }
        ]
      }
    ],

    // Stop — mix of fast sync and slow async
    "Stop": [
      {
        "hooks": [
          // Cache the last response for quick reference (fast, 23ms)
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh LastResponseCache.hook.ts" },
          // W10: TerminalState's Stop branch removed — completion tab is owned by handlers/TabState
          // inside StopOrchestrator (ordered fan-out), which avoids the prior multi-writer race on Stop.
          // Orchestrate stop-phase handlers (15s inference — must be async)
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh StopOrchestrator.hook.ts", "async": true },
          // Track algorithm phase progress (236ms, no stdout needed)
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh AlgorithmTracker.hook.ts", "async": true }
        ]
      }
    ],

    // PreCompact — runs before context window compaction
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh PreCompact.hook.ts" }
        ]
      }
    ],

    // ConfigChange — runs when configuration changes
    "ConfigChange": [
      {
        "hooks": [
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh ConfigChange.hook.ts" }
        ]
      }
    ],

    // WorktreeCreate — REMOVED: this event REPLACES built-in worktree creation.
    // A hook here must actually `git worktree add` and echo the path to stdout.
    // Our logging-only hook was breaking ALL worktree isolation by replacing
    // Claude Code's creation logic with a no-op. Let Claude handle it natively.
    // Audit logging moved to WorktreeRemove (notification-only, safe).

    // WorktreeRemove — runs when a git worktree is removed
    "WorktreeRemove": [
      {
        "hooks": [
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh WorktreeRemove.hook.ts" }
        ]
      }
    ],

    // TaskCompleted — runs when a task finishes
    "TaskCompleted": [
      {
        "hooks": [
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh TaskCompleted.hook.ts" }
        ]
      }
    ],

    // TeammateIdle — runs when a teammate agent becomes idle
    "TeammateIdle": [
      {
        "hooks": [
          { "type": "command", "command": "${PAI_DIR}/hooks/lib/run-hook.sh TeammateIdle.hook.ts" }
        ]
      }
    ]
  }
}
