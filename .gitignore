# Claude Code local settings (machine-specific, session-specific)
.claude/

# Claude Code runtime directories (session-specific, machine-specific)
# Per-project Claude Code state — never commit (memory may contain PII)
projects/
file-history/
debug/
todos/
session-env/
shell-snapshots/
paste-cache/
chrome/

# Claude Code command history
history.jsonl

# Node/Bun
node_modules/
**/node_modules/

# Statsig analytics (Claude Code creates this)
[Ss]tatsig/

# Bun build cache
*.bun-build

# Environment files (may contain API keys)
.env
.env.local
.env.*.local

# Credential files
devices.json

# Python bytecache
__pycache__/

# Cleanup state
.last-cleanup

# Playwright MCP cache (runtime snapshots)
.playwright-mcp/

# macOS
.DS_Store

# System state caches (regenerated automatically)
*.cache
*.log

# Accidental npm/bun debris
/package-lock.json

# Telemetry and analytics
telemetry/

# Runtime caches and backups
backups/
cache/

# Plugins (installed separately)
plugins/

# MEMORY — split between curated artifacts (committed) and runtime state (gitignored).
#
# Litmus test: "if lost on fresh clone, would I redo the work that produced it?"
#   YES → commit (WISDOM/FRAMES, KNOWLEDGE/*.md)
#   NO  → gitignore (state, signals, failures, staging drafts)
#
# WISDOM/FRAMES/ and KNOWLEDGE/*.md are intentionally tracked.
# Convention: WISDOM/FRAMES/ entries must be PII-free and portable (they ship in git).

# Runtime state — caches, session locks, telemetry
MEMORY/STATE/

# Work session PRDs — machine-local, session-specific
MEMORY/WORK/

# Relationship notes — may contain PII
MEMORY/RELATIONSHIP/

# Learning signals and raw failure captures — large, machine-local, may contain PII
MEMORY/LEARNING/
MEMORY/SECURITY/
MEMORY/RESEARCH/

# Staging drafts — auto-generated by ReflectionHarvester, expire in 14d, no cross-machine value
MEMORY/STAGING/

# KNOWLEDGE runtime cursor (not the distilled domain files — those are committed)
MEMORY/KNOWLEDGE/.harvest-state.json
MEMORY/KNOWLEDGE/INDEX.md

# CAPABILITIES — learned skills, contains project-specific paths and patterns (PII-adjacent)
MEMORY/CAPABILITIES/
CAPABILITIES.md
CAPABILITIES.md.template
TOOLS.md
TOOLS.md.template
TOOLS-FULL.md

# Session files (machine-specific, change every session)
sessions/

# Task state (ephemeral per-session)
tasks/

# MCP auth cache (machine-specific)
mcp-needs-auth-cache.json

# Generated from config/*.jsonc — do not commit (contains expanded personal paths)
settings.json
settings.json.backup*

# Local machine-specific overrides (created by installer migration or manually)
config/preferences.local.jsonc

# Settings backup files
*.bak
*.bak-*

# Skill runtime state files (machine-specific)
**/BugBountyTool/state.json

# Personal board config (user data — KAI ships board-config.template.json instead)
scripts/board-config.json

# Personal data (identity, contacts, TELOS, beliefs, etc.)
PAI/USER/
skills/PAI/USER/

# Local ADA packs/procedure configs.
# In this install ~/.claude is a symlink to pai-config, so ~/.claude/ada resolves here.
ada/

# Domain-specific example skills (not active, for reference only)
# skills-examples/ is tracked intentionally as templates

# Runtime skill state (never commit session-specific state)
skills/**/State/
skills-examples/**/State/
teams/investigation-*
teams/session-*/
# Per-machine update result (runtime state, not source)
.last-update-result.json

# Claude native/auto memory inbox.
# MEMORY.md can remain a tracked/indexed pointer if intentionally curated, but generated topic files
# are runtime/session artifacts and may come from unrelated projects.
auto-memory/*.md
!auto-memory/MEMORY.md
!auto-memory/codex-secondary-validator.md

# Memcarry durable lessons can be curated/tracked, but project resume-state atoms
# are runtime/session state and may be written by unrelated sessions/projects.
MEMORY/memcarry/store/atoms/project/

# Memcarry vendored core
memcarry/node_modules/
memcarry/**/node_modules/
memcarry/index/
memcarry/store/atoms/project/

# Embeddings index — rebuildable cache (bun scripts/EmbeddingIndex.ts --setup)
MEMORY/STATE/embeddings/

# Test temp artifacts (e.g. tests/.tmp-api-keys-test bun caches) — never commit or sync
tests/.tmp*
*.pile

# Personal automation profiles (Automate skill) — local only, like board-config.json
automations/
