# Claude Code runtime directories (session-specific, machine-specific)
projects/
file-history/
debug/
todos/
session-env/
shell-snapshots/
paste-cache/
chrome/

# Claude Code command history
history.jsonl

# Node/Bun
node_modules/
**/node_modules/

# Statsig analytics (Claude Code creates this)
[Ss]tatsig/

# Bun build cache
*.bun-build

# Environment files (may contain API keys)
.env
.env.local
.env.*.local

# Credential files
devices.json

# macOS
.DS_Store

# System state caches (regenerated automatically)
*.cache
*.log

# Accidental npm/bun debris
/package-lock.json

# Telemetry and analytics
telemetry/

# Runtime caches and backups
backups/
cache/

# Plugins (installed separately)
plugins/

# MEMORY — split between curated artifacts (committed) and runtime state (gitignored).
#
# Litmus test: "if lost on fresh clone, would I redo the work that produced it?"
#   YES → commit (WISDOM/FRAMES, KNOWLEDGE/*.md)
#   NO  → gitignore (state, signals, failures, staging drafts)
#
# WISDOM/FRAMES/ and KNOWLEDGE/*.md are intentionally tracked.
# Convention: WISDOM/FRAMES/ entries must be PII-free and portable (they ship in git).

# Runtime state — caches, session locks, telemetry
MEMORY/STATE/

# Work session PRDs — machine-local, session-specific
MEMORY/WORK/

# Relationship notes — may contain PII
MEMORY/RELATIONSHIP/

# Learning signals and raw failure captures — large, machine-local, may contain PII
MEMORY/LEARNING/
MEMORY/SECURITY/
MEMORY/RESEARCH/

# Staging drafts — auto-generated by ReflectionHarvester, expire in 14d, no cross-machine value
MEMORY/STAGING/

# KNOWLEDGE runtime cursor (not the distilled domain files — those are committed)
MEMORY/KNOWLEDGE/.harvest-state.json
MEMORY/KNOWLEDGE/INDEX.md

# CAPABILITIES — learned skills, contains project-specific paths and patterns (PII-adjacent)
MEMORY/CAPABILITIES/
CAPABILITIES.md

# Session files (machine-specific, change every session)
sessions/

# Task state (ephemeral per-session)
tasks/

# MCP auth cache (machine-specific)
mcp-needs-auth-cache.json

# Generated from config/*.jsonc — do not commit (contains expanded personal paths)
settings.json
settings.json.backup*

# Local machine-specific overrides (created by installer migration or manually)
config/preferences.local.jsonc

# Settings backup files
*.bak
*.bak-*

# Skill runtime state files (machine-specific)
**/BugBountyTool/state.json

# Personal data (identity, contacts, TELOS, beliefs, etc.)
PAI/USER/
skills/PAI/USER/

# Domain-specific example skills (not active, for reference only)
# skills-examples/ is tracked intentionally as templates

# Runtime skill state (never commit session-specific state)
skills/**/State/
skills-examples/**/State/
