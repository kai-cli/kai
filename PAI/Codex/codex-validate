#!/usr/bin/env bash
# codex-validate — get an independent second opinion from Codex (OpenAI gpt-5.5).
#
# Uses the standalone Codex CLI with the pinned `review` profile
# (gpt-5.5 + high reasoning effort) for consistent, maximally-capable validation.
# Runs with --ignore-user-config so the user's plugins/MCP servers/hooks do not
# leak into the review (reproducibility + independence). Always read-only.
#
# Usage:
#   codex-validate "<design / claim / question>"      # design/claim review
#   codex-validate -f path1 [path2 ...]               # review specific files
#   codex-validate diff                               # review uncommitted changes
#   codex-validate diff --base <branch>               # review current branch vs base
#   codex-validate diff --commit <sha>                # review a single commit
#
# Flags:
#   --json        emit structured JSON verdict (uses review-schema.json)
#   --plain       skip the structured schema even when it would apply
#   -C <dir>      set working directory for the review
#   --            end of options; everything after is positional
#
# Independence note: pass Codex the artifact and the question only — never your own
# conclusion ("confirm this is right"), which biases it toward agreement.

set -euo pipefail

CODEX="${CODEX_BIN:-$HOME/.local/bin/codex}"
SCHEMA="$HOME/.codex/review-schema.json"
PROFILE="review"

die() { echo "codex-validate: $*" >&2; exit 2; }
need() { [[ $# -ge 2 ]] || die "missing value for $1"; }   # $1=flag, rest=remaining args

emit_json=0
plain=0
cd_dir=""
mode="design"
end_opts=0
declare -a passthru=()    # diff-selector flags forwarded to `review`
declare -a files=()
prompt=""

# --- consume leading global options that may precede a subcommand -------------
# (lets `--json diff`, `--json -f file`, `-C dir diff` all work)
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)  emit_json=1; shift ;;
    --plain) plain=1; shift ;;
    -C)      need "$@"; cd_dir="$2"; shift 2 ;;
    *)       break ;;
  esac
done

# --- parse leading subcommand -------------------------------------------------
if [[ "${1:-}" == "diff" ]]; then
  mode="diff"; shift
elif [[ "${1:-}" == "-f" ]]; then
  mode="files"; shift
fi

# --- parse flags/args ---------------------------------------------------------
while [[ $# -gt 0 ]]; do
  if [[ $end_opts -eq 1 ]]; then
    if [[ "$mode" == "files" ]]; then files+=("$1"); else prompt="${prompt:+$prompt }$1"; fi
    shift; continue
  fi
  case "$1" in
    --)      end_opts=1; shift ;;
    --json)  emit_json=1; shift ;;
    --plain) plain=1; shift ;;
    -C)      need "$@"; cd_dir="$2"; shift 2 ;;
    --base)    [[ "$mode" == "diff" ]] || die "--base only valid in diff mode";   need "$@"; diff_base="$2";   passthru+=(--base "$2");   shift 2 ;;
    --commit)  [[ "$mode" == "diff" ]] || die "--commit only valid in diff mode"; need "$@"; diff_commit="$2"; passthru+=(--commit "$2"); shift 2 ;;
    --title)   need "$@"; passthru+=(--title "$2"); shift 2 ;;
    --uncommitted)
               [[ "$mode" == "diff" ]] || die "--uncommitted only valid in diff mode"; passthru+=(--uncommitted); shift ;;
    -*)      die "unknown flag: $1 (use -- to pass literal positionals)" ;;
    *)
      if [[ "$mode" == "files" ]]; then files+=("$1"); else prompt="${prompt:+$prompt }$1"; fi
      shift ;;
  esac
done

# --- shared exec base (read-only, pinned profile, isolated config) ------------
# --ignore-user-config isolates from user plugins/MCP/hooks but ALSO drops the
# profile's reasoning effort (model survives, effort resets to none), so re-pin
# both model and effort explicitly via -c overrides.
declare -a base=("$CODEX" exec -p "$PROFILE" --skip-git-repo-check -s read-only \
  --ignore-user-config -c model="gpt-5.5" -c model_reasoning_effort="high")
[[ -n "$cd_dir" ]] && base+=(-C "$cd_dir")

# Run a read-only review over a text instruction, with optional schema.
run_exec() {
  local instr="$1"
  local -a cmd=("${base[@]}")
  if [[ $emit_json -eq 1 && $plain -eq 0 ]]; then cmd+=(--output-schema "$SCHEMA"); fi
  "${cmd[@]}" "$instr"
}

# Compute the git diff text for the selected scope (used only for --json diff,
# because the native `review` subcommand ignores --output-schema).
compute_diff() {
  local d
  if [[ -n "${diff_commit:-}" ]]; then
    d="$(git show --no-ext-diff "$diff_commit" 2>/dev/null)"
  elif [[ -n "${diff_base:-}" ]]; then
    d="$(git diff --no-ext-diff "$diff_base"...HEAD 2>/dev/null)"
  else
    d="$(git diff --no-ext-diff HEAD 2>/dev/null; git diff --no-ext-diff --cached 2>/dev/null)"
  fi
  printf '%s' "$d"
}

case "$mode" in
  diff)
    if [[ $emit_json -eq 1 && $plain -eq 0 ]]; then
      # Native `review` ignores --output-schema, so to get a structured verdict
      # we feed the diff text through the schema-capable exec path instead.
      [[ -n "$cd_dir" ]] && cd "$cd_dir"
      diff_text="$(compute_diff)"
      [[ -n "$diff_text" ]] || die "no changes to review for the requested diff scope"
      run_exec "Independently review this git diff. Report risks, bugs, and recommendations; do not assume it is correct.

$diff_text"
    else
      # Prose review via the native diff-aware subcommand.
      # Exec-level flags (-p, -s, --ignore-user-config) MUST precede `review`;
      # diff selectors cannot be combined with a trailing PROMPT.
      [[ ${#passthru[@]} -eq 0 ]] && passthru+=(--uncommitted)
      "${base[@]}" review "${passthru[@]}"
    fi
    ;;
  files)
    [[ ${#files[@]} -gt 0 ]] || die "-f: no files given"
    for f in "${files[@]}"; do [[ -e "$f" ]] || die "no such file: $f"; done
    printf -v file_list '%q ' "${files[@]}"
    run_exec "Independently review the following file(s): ${file_list}. Read them, then report risks, bugs, and recommendations. Do not assume they are correct."
    ;;
  design)
    [[ -n "$prompt" ]] || die "nothing to review (give a prompt, -f files, or 'diff')"
    run_exec "Independently review the following. Report risks and recommendations; do not assume it is correct.

$prompt"
    ;;
esac
